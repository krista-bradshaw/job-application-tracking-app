# Frontend feature flags
# Set to "true" to enable AI job description analysis features (requires VITE_GEMINI_API_KEY)
VITE_ENABLE_AI_FEATURES=false

# Gemini API key (only needed if VITE_ENABLE_AI_FEATURES=true)
# Get one at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Supabase — required
# Create a project at https://supabase.com, then copy from Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
